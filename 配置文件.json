{
  "_注释": "NoVNC屏幕墙配置文件 - 修改后保存,启动时自动读取",

  "layout": {
    "rows": 5,
    "cols": 5,
    "gap": 2,
    "_注释": "rows x cols 网格布局, gap=单元格间距像素"
  },

  "window": {
    "fullscreen": false,
    "width": 1920,
    "height": 1080,
    "title": "NoVNC 屏幕墙",
    "backgroundColor": "#111111",
    "_注释": "fullscreen=true 启动即全屏, false 则用 width x height"
  },

