  "vnc": {
    "urlTemplate": "http://{ip}:5801/vnc_video.html?autoconnect=true&host={ip}&port=5901&encrypt=0",
    "stagger": 300,
    "_注释": "urlTemplate 用 {ip} 占位, stagger=每个设备启动错峰间隔毫秒"
  },

  "ui": {
    "showLabel": true,
    "labelColor": "#00ff00",
    "labelBg": "rgba(0,0,0,0.75)",
    "showStatusDot": true,
    "_注释": "showLabel=显示设备名标签, showStatusDot=显示右上角连接状态点"
  }
}
